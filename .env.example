# ─── Database ────────────────────────────────────────────────────────────────
# Neon (serverless Postgres). Prisma (Performance OS) uses DATABASE_URL and
# manages the `public` schema; Finance OS (Drizzle) uses the same URL by
# default and keeps its tables in the `finance_os` schema.
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
# Optional: separate database for Finance OS (falls back to DATABASE_URL)
# FINANCE_DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# ─── Market data — Finnhub (Phase 2) ─────────────────────────────────────────
FINNHUB_API_KEY=""
# Which provider to use (finnhub; alphavantage planned)
# MARKET_DATA_PROVIDER="finnhub"

# ─── Trading212 read-only sync (Phase 3) ─────────────────────────────────────
T212_API_KEY=""
T212_API_SECRET=""
# live | demo (use demo for development and testing). If the key belongs to
# the other environment, the client detects it on first auth failure.
T212_ENV="demo"

# ─── Cron protection (Phase 2+) ──────────────────────────────────────────────
# Vercel Cron calls /api/cron/* with Authorization: Bearer ${CRON_SECRET}
CRON_SECRET=""

# ─── E-mail notifications — Resend (Phase 5) ─────────────────────────────────
RESEND_API_KEY=""
ALERT_EMAIL_TO=""

# ─── App passcode lock ───────────────────────────────────────────────────────
# Numeric PIN that gates the whole app. Leave empty to disable the lock.
# The lock activates only when APP_PIN is set (and a signing secret exists).
APP_PIN=""
# HMAC key for the unlock cookie. Falls back to CRON_SECRET when unset.
APP_SESSION_SECRET=""
